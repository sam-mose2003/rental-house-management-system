{
  "name": "rental-house-management-system",
  "version": "2.0.0",
  "description": "A modern, user-friendly web application for managing rental properties with approval workflows and role-based access",
  "main": "backend/app.py",
  "directories": {
    "doc": "docs",
    "lib": "backend/lib"
  },
  "scripts": {
    "start": "concurrently \"npm run backend\" \"npm run frontend\"",
    "backend": "cd backend && python app.py",
    "frontend": "cd frontend && npm run dev",
    "setup": "npm install && cd frontend && npm install",
    "setup-db": "mysql -u root -p < backend/schema.sql",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "build": "cd frontend && npm run build",
    "lint": "cd frontend && npm run lint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YOUR_USERNAME/rental-house-management-system.git"
  },
  "keywords": [
    "rental-management",
    "property-management",
    "tenant-portal",
    "flask",
    "react",
    "mysql",
    "approval-workflow",
    "real-estate"
  ],
  "author": "RHMS Development Team",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/YOUR_USERNAME/rental-house-management-system/issues"
  },
  "homepage": "https://github.com/YOUR_USERNAME/rental-house-management-system#readme",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "python": ">=3.8"
  }
}
