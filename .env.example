# 🏠 Rental House Management System - Environment Configuration
# Copy this file to .env and update with your actual values

# 🗄️ Database Configuration
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=rhms

# 🔐 Flask Configuration
FLASK_SECRET_KEY=rhms_secret_key_change_in_production_please
FLASK_ENV=development
FLASK_DEBUG=True

# 🌐 Frontend URLs for CORS
FRONTEND_URL=http://localhost:5173
FRONTEND_URL_ALT=http://localhost:5176
FRONTEND_URL_LOCAL=http://127.0.0.1:5173
FRONTEND_URL_LOCAL_ALT=http://127.0.0.1:5176

# 🖥️ Server Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=5000
FRONTEND_PORT=5173

# 📧 Email Configuration (Optional - for notifications)
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=admin@rhms.com

# 🔧 Application Settings
APP_NAME=Rental House Management System
APP_VERSION=2.0.0
TIMEZONE=UTC
DEFAULT_CURRENCY=KES

# 🛡️ Security Settings
JWT_SECRET_KEY=jwt_secret_key_change_in_production
SESSION_TIMEOUT=3600
MAX_LOGIN_ATTEMPTS=5

# 📊 Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/rhms.log
ENABLE_ACCESS_LOGS=True
