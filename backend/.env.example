# Email Configuration for RHMS
# Copy this file to .env and update with your actual email settings

# Gmail SMTP Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_app_password

# Enable/Disable email notifications
EMAIL_ENABLED=true

# Note: For Gmail, you need to:
# 1. Enable 2-factor authentication
# 2. Generate an App Password: https://myaccount.google.com/apppasswords
# 3. Use the App Password (16 characters) as SENDER_PASSWORD
# 4. Replace your_email@gmail.com with your actual Gmail address
