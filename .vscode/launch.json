    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Frontend (Tenant Portal)",
            "request": "launch",
            "type": "chrome",
            "url": "http://localhost:5176",
            "webRoot": "${workspaceFolder}/frontend"
        },
        {
            "name": "Launch Admin Dashboard (Flask)",
            "request": "launch",
            "type": "chrome", 
            "url": "http://localhost:5000/dashboard",
            "webRoot": "${workspaceFolder}"
        },
        {
            "name": "Launch Admin Choice Page",
            "request": "launch",
            "type": "chrome",
            "url": "http://localhost:5000",
            "webRoot": "${workspaceFolder}"
        }
    ],
    "compounds": [
        {
            "name": "Launch Full RHMS System",
            "configurations": [
                "Launch Frontend (Tenant Portal)",
                "Launch Admin Dashboard (Flask)"
            ]
        }
    ]
}